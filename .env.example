# 프론트 → 백엔드 API 주소 설정 예시.
#
# 로컬 풀스택 개발 시 이 파일을 .env.local 로 복사하세요 (.env.local 은 gitignore됨):
#   Copy-Item .env.example .env.local      (PowerShell)
#   cp .env.example .env.local             (mac/linux)
#
# 백엔드 dev 런처(backend/dev.ps1, dev.sh)를 쓰면 이 파일이 자동 생성됩니다.
# 미설정 시 client.ts 의 운영 폴백 주소가 사용됩니다.

EXPO_PUBLIC_API_URL=http://localhost:8080
